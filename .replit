modules = ["python-3.12", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cacert", "cairo", "ffmpeg-full", "freetype", "gdb", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "libcxx", "libjpeg_turbo", "libpng", "libxcrypt", "ncurses", "pkg-config", "qhull", "tcl", "tk", "which", "xsimd"]
